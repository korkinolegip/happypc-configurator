# База данных
POSTGRES_DB=happypc
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-strong-password-here

# Безопасность
SECRET_KEY=your-very-long-random-secret-key-change-this

# Ссылки
FRONTEND_URL=https://your-domain.com
BACKEND_URL=https://your-domain.com

# Telegram авторизация (опционально)
# 1. Создайте бота через @BotFather
# 2. Вставьте токен и имя бота ниже
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_NAME=

# VK авторизация (опционально)
# 1. Создайте приложение на https://vk.com/dev
# 2. Тип: Web, укажите redirect URI: https://your-domain.com/auth/vk/callback
VK_CLIENT_ID=
VK_CLIENT_SECRET=
